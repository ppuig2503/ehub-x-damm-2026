{
  "name": "smartbuy-signal-os",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm --prefix frontend run dev\" \"python -m uvicorn backend.app.main:app --reload --port 8000\"",
    "dev:web": "npm --prefix frontend run dev",
    "dev:api": "python -m uvicorn backend.app.main:app --reload --port 8000",
    "build:web": "npm --prefix frontend run build",
    "lint:web": "npm --prefix frontend run lint",
    "seed": "python -m backend.scripts.build_seed_data",
    "test:api": "python -m pytest backend/tests"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
